{
  "name": "agent-deck",
  "version": "1.0.0",
  "type": "module",
  "description": "Web-based command center for monitoring and managing multiple AI coding agents. Supports Claude Code, Codex, Gemini CLI, and any LiteLLM-compatible model.",
  "keywords": [
    "ai",
    "agent",
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "litellm",
    "monitoring",
    "dashboard",
    "command-center",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/claude-world/agent-deck"
  },
  "homepage": "https://github.com/claude-world/agent-deck",
  "bin": {
    "agent-deck": "./bin/agent-deck.js"
  },
  "files": [
    "bin/",
    "dist/",
    "server/",
    "team-configs/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --port 5200",
    "start": "tsx server/index.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-use-websocket": "^4.13.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
